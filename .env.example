# Graph-RCA — Environment Variables
# Copy this file to .env and fill in your values.
# For Docker deployments, pass these via `docker compose --env-file .env up`.

# ---------------------------------------------------------------------------
# Required: MongoDB connection URI
#
# When running the backend on the HOST (e.g. local uvicorn), Mongo is
# reachable at localhost:
#   MONGO_URI=mongodb://admin:<MONGO_PASSWORD>@localhost:27017/
#
# When running via docker-compose, the compose file builds the URI from
# MONGO_USERNAME / MONGO_PASSWORD automatically — only override if you're
# pointing at an external cluster (e.g. MongoDB Atlas).
# ---------------------------------------------------------------------------
# MONGO_URI=mongodb://admin:changeme@localhost:27017/

# ---------------------------------------------------------------------------
# Optional: Ollama service hosts
# OLLAMA_HOST is used by host-run backend (e.g. local uvicorn).
# BACKEND_OLLAMA_HOST is used by docker-compose backend service and defaults
# to in-network DNS http://ollama:11434, so usually no override is needed.
# ---------------------------------------------------------------------------
# OLLAMA_HOST=http://localhost:11435
# BACKEND_OLLAMA_HOST=http://ollama:11434

# ---------------------------------------------------------------------------
# Optional: API keys for LLM judge experiments (07 and 08)
# These are REQUIRED when running experiments/07_multi_judge_validation or
# experiments/08_rag_real_world with gpt or groq judges.
# Multiple keys can be comma-separated for automatic rotation on rate limits.
# ---------------------------------------------------------------------------
OPENAI_API_KEY=__YOUR_OPENAI_KEY_HERE__
GROQ_API_KEY=__YOUR_GROQ_KEY_HERE__

# ---------------------------------------------------------------------------
# Optional: Ollama model configuration
# These control which models are used throughout the pipeline.
# Override these to switch models without editing any code.
# ---------------------------------------------------------------------------
# OLLAMA_MODEL=llama3.2:3b
# EMBEDDING_MODEL=nomic-embed-text
# OLLAMA_TIMEOUT=30.0
# OLLAMA_TEMPERATURE=0.2
# RAG_CHUNK_SIZE=1000
# RAG_CHUNK_OVERLAP=200

# ---------------------------------------------------------------------------
# Optional: CORS allowed origins (comma-separated)
# Default: http://localhost:5173,http://localhost:3000
# Change this if your frontend is served from a different origin.
# ---------------------------------------------------------------------------
# ALLOWED_ORIGINS=https://myrca.example.com,http://localhost:5173

# ---------------------------------------------------------------------------
# Optional: ChromaDB persistence directory
# Default: ./data/chroma (resolved from project root)
# ---------------------------------------------------------------------------
# CHROMADB_PATH=./data/chroma

# ---------------------------------------------------------------------------
# Optional: Backend security & operations
# - API_KEY: when set, every /api/* request (except /api/health) must
#   include `X-API-Key: <value>`. Leave unset for local-only use.
# - RATE_LIMIT_PER_MINUTE: max requests per IP per 60s window (default 60).
# - UVICORN_WORKERS: keep at 1 unless rate-limit state is in a shared
#   store; multi-worker multiplies the effective rate limit.
# - LOG_JSON: 1 (default) emits JSON-structured logs; 0 emits human-readable.
# ---------------------------------------------------------------------------
# API_KEY=
# RATE_LIMIT_PER_MINUTE=60
# UVICORN_WORKERS=1
# LOG_JSON=1

# ---------------------------------------------------------------------------
# Docker Compose: MongoDB credentials (referenced in docker-compose.yaml)
# These build the default in-network MONGO_URI for the backend container.
# ---------------------------------------------------------------------------
MONGO_USERNAME=admin
MONGO_PASSWORD=__REPLACE_ME__
